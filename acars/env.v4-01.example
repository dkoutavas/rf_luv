# ACARS pipeline environment file for V4 dongle deployment on leap.
#
# Copy to acars/.env on the host running docker-compose (leap):
#   cp env.v4-01.example .env
# .env is consumed by docker-compose for ${VAR} substitution.
#
# Per the decoding-roadmap dongle-assignment policy, V4 is dedicated to
# narrow-band decoders (no FM filter required, hot-lockup history but
# auto-recovers via the rtl-tcp escalator). V3 stays on scanning.
#
# IMPORTANT: this pipeline shares V4 with rtl-tcp@v4-01.service (port 1235
# on leap). Two consumers cannot connect to rtl_tcp simultaneously, so
# rtl-scanner@v4-01.service must be stopped before starting acarsdec:
#
#   systemctl --user stop rtl-scanner@v4-01.service
#   systemctl --user disable rtl-scanner@v4-01.service
#
# Keep rtl-tcp@v4-01.service running — its watchdog/escalator stack is what
# auto-recovers V4 from hot-lockup. acarsdec connects to it as a TCP client.

# ── Tuner: rtl_tcp connection via SoapySDR ───────────────
# SOAPYSDR is the full SoapySDR device string passed to acarsdec via -d.
# For rtl_tcp on leap (V4 on port 1235):
SOAPYSDR=driver=rtltcp,rtltcp=192.168.2.10:1235

# ── ACARS frequencies (European plan) ───────────────────
# acarsdec accepts up to 5 channels in one ~2 MHz tuning window centered
# on the median. 131.525/131.725/131.825 spans ~300 kHz, well within range.
# Semicolon-separated per the docker-acarsdec convention.
ACARS_FREQUENCIES=131.525;131.725;131.825

# ── Tuner gain ──────────────────────────────────────────
# RTL gain in dB. -10 = autogain (often noisier than fixed). Start at 30,
# watch err_count in the dashboard; if it climbs over 0.3 avg, drop by 5.
ACARS_GAIN=30

# ── Frequency calibration ───────────────────────────────
# PPM correction. Leave at 0 unless V4's TCXO drift was characterized.
ACARS_PPM=0

# ── Identity / classifier feedback ──────────────────────
# Tagged on every row in acars.messages so cross-pipeline queries can
# attribute messages to the source dongle.
ACARS_DONGLE_ID=v4-01

# Feed ID embedded by acarsdec in the JSON output. Distinguishes this
# instance from any future second ACARS receiver.
ACARS_FEED_ID=rf_luv-v4-01

# ── Logging ─────────────────────────────────────────────
ACARS_QUIET_LOGS=false
TZ=UTC

# ── Ingest tuning ───────────────────────────────────────
# ACARS at LGAV is sparse-but-bursty; small batch + long flush keeps
# dashboards responsive without over-INSERTing.
BATCH_SIZE=100
FLUSH_INTERVAL_SECONDS=10

# ── ClickHouse ──────────────────────────────────────────
# Default password is dev-only. For leap, set to a non-trivial value
# and grep ais/ ism/ for the equivalent leap secret pattern (env-only,
# not committed).
CLICKHOUSE_PASSWORD=acars_local
