# /etc/rtl-scanner/notify.env — copy this file (NOT into git) and fill in the
# topic generated in the ntfy mobile app. Subscribe to the same topic in the
# app on your phone.
#
# Pick a long random topic name (anyone who knows the topic can read AND
# write to it on the public ntfy.sh server). E.g. rf_luv_<8-random-chars>.
#
# To self-host instead, point NTFY_URL at your own ntfy server.
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh
