# rtl-scanner environment file for v3-01 (RTL-SDR Blog V3 on leap)
#
# Install to /etc/rtl-scanner/v3-01.env. Consumed by both
# rtl-tcp@v3-01.service (for RTL_TCP_* vars) and rtl-scanner@v3-01.service
# (for all SCAN_* and CLICKHOUSE_* vars).
#
# These values match current production (spectrum-scanner docker-compose
# service) as of 2026-04-22: adaptive gain between 2-12 dB, stock dipole
# on rooftop tripod 3m up, no filter. Source of truth during the cutover
# is spectrum/docker-compose.yml — keep in sync.

# ── Identity ─────────────────────────────────────────────
# Must match the dongle serial written via rtl_eeprom. See
# spectrum/docs/dongle_identity.md.
SCAN_DONGLE_ID=v3-01

# ── rtl_tcp ──────────────────────────────────────────────
# Host/port the SCANNER connects to (localhost, since rtl-tcp@v3-01 runs
# on the same host). The BIND / SAMPLE_RATE vars are consumed by
# rtl-tcp@v3-01.service's ExecStart.
RTL_TCP_HOST=127.0.0.1
RTL_TCP_PORT=1234
RTL_TCP_BIND=0.0.0.0
RTL_TCP_SAMPLE_RATE=2048000

# ── Sweep configuration ──────────────────────────────────
SCAN_FREQ_START=88000000
SCAN_FREQ_END=470000000
SCAN_BIN_WIDTH=100000
SCAN_GAIN=12
SCAN_GAIN_MIN=2
SCAN_FFT_SIZE=1024
SCAN_SAMPLE_RATE=2048000
SCAN_NUM_AVERAGES=8
SCAN_INTERVAL_SECONDS=280
SCAN_AIRBAND_INTERVAL=60
SCAN_AIRBAND_START=118000000
SCAN_AIRBAND_END=137000000
SCAN_PEAK_THRESHOLD=10
SCAN_PEAK_NEIGHBORS=5
SCAN_TRANSIENT_THRESHOLD=15

# ── Antenna tracking (recorded per run for A/B comparisons) ──────────
SCAN_ANTENNA_POSITION=rooftop_tripod
SCAN_ANTENNA_ARMS_CM=57
SCAN_ANTENNA_ORIENTATION=165
SCAN_ANTENNA_HEIGHT_M=3
SCAN_NOTES=Stock dipole on rooftop tripod, 3m height, same arm config

# ── ClickHouse ───────────────────────────────────────────
# Scanner writes via scan_ingest.py. Matches spectrum-features /
# spectrum-classifier / classifier-health env.
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8126
CLICKHOUSE_DB=spectrum
CLICKHOUSE_USER=spectrum
CLICKHOUSE_PASSWORD=spectrum_local

# ── Ingest ───────────────────────────────────────────────
BATCH_SIZE=500
FLUSH_INTERVAL_SECONDS=5
