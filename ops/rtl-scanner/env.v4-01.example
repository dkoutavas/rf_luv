# rtl-scanner environment file for v4-01 (RTL-SDR Blog V4 with FM bandstop
# filter — A/B week configuration).
#
# Install to /etc/rtl-scanner/v4-01.env AFTER populating TODO items below.
# Consumed by rtl-tcp@v4-01.service and rtl-scanner@v4-01.service.
#
# V4 is added for a 7-day A/B filter evaluation: we measure the FM bandstop
# filter's effect on noise floor, clip rate, and signal discovery. After the
# A/B decision (filter migrates to V3), this file will be rewritten for V4's
# specialist role (see spectrum/docs/ab_comparison.md for the post-A/B plan).

# ── Identity ─────────────────────────────────────────────
# Must match the V4 serial written via rtl_eeprom. See
# spectrum/docs/dongle_identity.md for the serial-write procedure.
SCAN_DONGLE_ID=v4-01

# ── rtl_tcp ──────────────────────────────────────────────
# Port 1235 so V3 (1234) and V4 (1235) coexist. BIND=0.0.0.0 is fine even on a
# single-host deployment — the firewall governs external access.
RTL_TCP_HOST=127.0.0.1
RTL_TCP_PORT=1235
RTL_TCP_BIND=0.0.0.0
RTL_TCP_SAMPLE_RATE=2048000

# ── Sweep configuration ──────────────────────────────────
# Mirrors V3 during A/B week so dongle_comparison_view has apples-to-apples
# deltas. Post-A/B, retune to V4's specialist band.
SCAN_FREQ_START=88000000
SCAN_FREQ_END=470000000
SCAN_BIN_WIDTH=100000

# TODO(gain): recalibrate for V4's front-end on first start. V3's SCAN_GAIN=12
# SCAN_GAIN_MIN=2 is not portable — V4's R828D tuner has a different gain-
# compression curve, and the FM filter changes the dynamic-range budget
# (less in-band power → can afford higher gain without clipping). Start
# conservatively with SCAN_GAIN=20 SCAN_GAIN_MIN=2, watch sweep_health
# (especially max_clip_fraction in the FM band) and adjust. Once tuned,
# record the final values and delete this TODO.
SCAN_GAIN=20
SCAN_GAIN_MIN=2

SCAN_FFT_SIZE=1024
SCAN_SAMPLE_RATE=2048000
SCAN_NUM_AVERAGES=8
SCAN_INTERVAL_SECONDS=280
SCAN_AIRBAND_INTERVAL=60
SCAN_AIRBAND_START=118000000
SCAN_AIRBAND_END=137000000
SCAN_PEAK_THRESHOLD=10
SCAN_PEAK_NEIGHBORS=5
SCAN_TRANSIENT_THRESHOLD=15

# ── Antenna tracking ─────────────────────────────────────
# TODO(antenna): fill in the actual V4 antenna configuration. If V4 shares
# V3's antenna via a splitter, record that; if separate antenna, record
# its position/height/orientation. These values live in scan_runs and are
# used when diagnosing post-hoc why V4 saw a signal V3 missed (or vice versa).
SCAN_ANTENNA_POSITION=TODO_rooftop_v4_position
SCAN_ANTENNA_ARMS_CM=57
SCAN_ANTENNA_ORIENTATION=165
SCAN_ANTENNA_HEIGHT_M=3
SCAN_NOTES=V4 with FM bandstop filter inline (A/B week configuration)

# ── ClickHouse ───────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8126
CLICKHOUSE_DB=spectrum
CLICKHOUSE_USER=spectrum
CLICKHOUSE_PASSWORD=spectrum_local

# ── Ingest ───────────────────────────────────────────────
BATCH_SIZE=500
FLUSH_INTERVAL_SECONDS=5
