# rf-freshness-probe runtime overrides (optional).
#
# Installed at /etc/rtl-scanner/freshness-probe.env by
# ops/install-trip-hardening.sh; the systemd unit reads via
# `EnvironmentFile=-/etc/rtl-scanner/freshness-probe.env` (`-` = optional,
# probe falls back to script defaults if the file is missing).

# ── Which dongles must be writing to spectrum.scans? ──
# Comma-separated dongle IDs. The probe alerts when one of these has
# stopped producing fresh rows.
#
# Default in script: v3-01,v4-01 (legacy two-scanner config).
#
# Reality after 2026-05-02: V4 was reassigned to the ACARS pipeline
# (acars/) so it no longer writes to spectrum.scans. Listing only V3
# here prevents a permanent WARN/CRITICAL state from V4's "staleness"
# (which is correct — V4 just isn't a scanner anymore).
EXPECTED_DONGLES=v3-01

# ── Staleness thresholds (seconds) ──
# Tune up if your sweep cadence is slow, or down if you want tighter alerting.
# FRESHNESS_WARN_S=600
# FRESHNESS_CRITICAL_S=1500
