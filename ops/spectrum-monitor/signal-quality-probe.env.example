# rf-signal-quality-probe runtime overrides (optional).
#
# Installed at /etc/rtl-scanner/signal-quality-probe.env by
# ops/install-trip-hardening.sh; the systemd unit reads via
# `EnvironmentFile=-/etc/rtl-scanner/signal-quality-probe.env`.

# ── Which dongles must be producing healthy spectrum.sweep_health rows? ──
# Same logic as freshness-probe — V4 was reassigned to ACARS on 2026-05-02
# and no longer produces spectrum sweeps, so listing only V3 prevents
# false-positive deaf-scanner alarms once V4 falls out of the lookback
# window.
EXPECTED_DONGLES=v3-01

# ── Signal level thresholds (dBFS over the last 30 min) ──
# Default: WARN at < -35 dBFS, CRITICAL at < -40 dBFS. Tune per antenna.
# SIGNAL_QUALITY_WARN_DBFS=-35
# SIGNAL_QUALITY_CRITICAL_DBFS=-40
