# Spectrum scanner — environment overrides for docker-compose
#
# Copy to spectrum/.env to take effect: `cp spectrum/.env.example spectrum/.env`
# Only set what you need to change; defaults below match the in-source values.
#
# ─── rtl_tcp (where the dongle is streaming from) ───────────────────────────
# host.docker.internal works on Docker Desktop / WSL2 and Linux Docker 20.10+.
# For containers reaching a remote rtl_tcp, set the host's IP/hostname instead.
#RTL_TCP_HOST=host.docker.internal
#RTL_TCP_PORT=1234

# ─── Sweep range and resolution ─────────────────────────────────────────────
# Defaults cover FM broadcast through UHF pagers (88-470 MHz). For HF, use
# direct-sampling mode on a V3 dongle and shrink the range to 0.5-28 MHz.
#SCAN_FREQ_START=88000000
#SCAN_FREQ_END=470000000
#SCAN_BIN_WIDTH=100000
#SCAN_FFT_SIZE=1024
#SCAN_SAMPLE_RATE=2048000

# ─── Gain — adapt to your antenna + RF environment ──────────────────────────
# Start at 12 dB; the scanner auto-reduces on ADC clipping down to SCAN_GAIN_MIN.
# In a strong-FM-dominated environment (e.g. near broadcast transmitters) try
# inserting an FM bandstop filter before raising gain past ~10 dB.
#SCAN_GAIN=12
#SCAN_GAIN_MIN=2

# ─── Sweep cadence ──────────────────────────────────────────────────────────
# Full band sweeps every ~5 minutes; airband (118-137 MHz) sweeps every 60s
# for fast ATC capture. Both presets share the dongle.
#SCAN_INTERVAL_SECONDS=280
#SCAN_AIRBAND_INTERVAL=60
#SCAN_AIRBAND_START=118000000
#SCAN_AIRBAND_END=137000000

# ─── Peak / transient detection thresholds ──────────────────────────────────
#SCAN_PEAK_THRESHOLD=10        # bin must exceed neighbor avg by this many dB
#SCAN_PEAK_NEIGHBORS=5         # neighbors averaged on each side
#SCAN_TRANSIENT_THRESHOLD=15   # |delta| vs prior sweep to log appeared/disappeared

# ─── DVB-T exclusion zone (for clipping reports) ────────────────────────────
# Strong DVB-T transmitters in this range are expected — the scanner reports
# their power separately so they don't mask other clipping. Set for your
# country's Band III plan: Greece 174-230 MHz, US doesn't use this band.
#SCAN_DVBT_EXCLUDE_START=174000000
#SCAN_DVBT_EXCLUDE_END=230000000

# ─── Dongle identity ────────────────────────────────────────────────────────
# Should match the EEPROM-written serial of your RTL-SDR (rtl_eeprom -d <N>).
# For multi-dongle deployments, run one scanner+ingest pair per dongle.
#SCAN_DONGLE_ID=v3-01

# ─── Antenna metadata (recorded with each run for A/B comparisons) ──────────
# Free-form strings — used in scan_runs row only, never in DSP path.
#SCAN_ANTENNA_POSITION=
#SCAN_ANTENNA_ARMS_CM=
#SCAN_ANTENNA_ORIENTATION=
#SCAN_ANTENNA_HEIGHT_M=
#SCAN_NOTES=

# ─── ClickHouse (defaults match docker-compose service) ─────────────────────
# In-container default: clickhouse:8123. Host-side scripts default to
# localhost:8126 (the host-port mapping). spectrum-scanner inside compose
# uses CLICKHOUSE_HOST=clickhouse, CLICKHOUSE_PORT=8123 explicitly.
#CLICKHOUSE_HOST=clickhouse
#CLICKHOUSE_PORT=8123
#CLICKHOUSE_DB=spectrum
#CLICKHOUSE_USER=spectrum
#CLICKHOUSE_PASSWORD=spectrum_local

# ─── Ingest batching ────────────────────────────────────────────────────────
#BATCH_SIZE=500
#FLUSH_INTERVAL_SECONDS=5

# ─── Grafana — CHANGE BEFORE EXPOSING :3003 PUBLICLY ────────────────────────
#GF_SECURITY_ADMIN_USER=admin
#GF_SECURITY_ADMIN_PASSWORD=admin
