        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT seconds_since_last_sweep FROM spectrum.classifier_health ORDER BY computed_at DESC LIMIT 1",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
