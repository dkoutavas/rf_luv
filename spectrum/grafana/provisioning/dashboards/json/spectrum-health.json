    {
      "type": "timeseries",
      "title": "Regression sentinels (all should sit at 0)",
      "description": "Four signals that are 0 when the cleanup fixes are holding. Any non-zero line is a regression: precision_tails = Float32 wobble returned (fd5016e); xalloc_harmonics = same-allocation check broke (2b12a70); continuous_with_bursts = burst filter broke (43744b6); distinct_conf_minus_5 = unexpected confidence values.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT computed_at AS time,   confidence_precision_tail_count AS precision_tails,   harmonic_flags_cross_allocation AS xalloc_harmonics,   continuous_signals_with_bursts AS continuous_with_bursts,   toInt32(confidence_distinct_values) - 5 AS distinct_conf_minus_5 FROM spectrum.classifier_health WHERE $__timeFilter(computed_at) ORDER BY time",
          "format": 0
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
